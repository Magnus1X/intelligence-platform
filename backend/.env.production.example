# ─────────────────────────────────────────────────────────────
# Copy every key below into Render → Environment Variables
# DO NOT commit this file with real values
# ─────────────────────────────────────────────────────────────

NODE_ENV=production

# Render assigns PORT automatically — do NOT set this in Render
# PORT=10000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://magnusxdb:Saurav123@portfolio-db.jwnqrs3.mongodb.net/intelligence_platform?retryWrites=true&w=majority

# JWT — use a long random string (min 32 chars)
JWT_SECRET=replace_with_a_very_long_random_secret_string_here
JWT_EXPIRES_IN=7d

# Your deployed frontend URL (set AFTER frontend is deployed)
# Example: https://intelligence-platform.onrender.com
CLIENT_URL=https://your-frontend-url.onrender.com

